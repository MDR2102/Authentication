#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo '🚀 Running pre-commit code quality checks...'

# Capture the list of staged files (excluding package.json and lock files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v -E '(package-lock\.json|yarn\.lock|pnpm-lock\.yaml)$')

# First, auto-fix what we can
echo '🔧 Auto-fixing Prettier issues...'
npm run prettier:fix || {
    echo '⚠️  Prettier fix had issues, but continuing...'
}

echo '🔧 Auto-fixing ESLint issues...'
npm run lint:fix || {
    echo '⚠️  ESLint fix had issues, but continuing...'
}

# Add only the originally staged files back (after auto-fixes)
if [ -n "$STAGED_FILES" ]; then
    echo "$STAGED_FILES" | xargs git add
fi

   
# Verify Prettier standards
echo '🎨 Checking Prettier formatting...'
npm run prettier:check || {
    echo '❌ Prettier check failed. This should not happen after auto-fix.'
    exit 1
}
echo '✅ Prettier standards looking good!'


# Verify ESLint standards
echo '📋 Checking ESLint rules...'
npm run lint || {
    echo '❌ ESLint check failed. Some issues could not be auto-fixed.'
    echo '   Please fix the remaining issues manually and try again.'
    exit 1
}
echo '✅ ESLint standards looking good!'

echo '🐍 Running pylint for server-py...'
(cd server-py && python -m pylint app) || {
    echo '❌ Pylint failed for server-py. Fix backend lint errors before committing.'
    exit 1
}
echo '✅ Pylint checks passed!'

echo '✅✅✅✅ All checks passed! Committing now... ✅✅✅✅'
exit 0